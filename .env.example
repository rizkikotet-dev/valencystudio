# Database
DATABASE_URL="file:./db/prod.db"

# Discord OAuth (https://discord.com/developers/applications)
AUTH_DISCORD_ID=your_discord_client_id
AUTH_DISCORD_SECRET=your_discord_client_secret

# NextAuth
AUTH_SECRET=generate_with_openssl_rand_-base64_32
AUTH_URL=http://localhost:3000

# Discord Webhook (optional) — untuk notifikasi login user ke channel Discord
DISCORD_LOG_WEBHOOK_URL=

# Discord Bot (https://discord.com/developers/applications → Bot)
BOT_TOKEN=your_discord_bot_token
GUILD_ID=your_discord_server_id
LOG_CHANNEL_ID=channel_id_for_member_logs
STATUS_CHANNEL_ID=channel_id_for_server_status
